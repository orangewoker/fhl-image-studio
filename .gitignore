# Generated images, raw SSE dumps, imported sources
# (raw SSE files include request headers — may leak API keys)
/images/
/input/*
!/input/.gitkeep
/output/*
!/output/.gitkeep
!/output/log/
/output/log/*
!/output/log/.gitkeep
/intermediate/*
!/intermediate/.gitkeep
/image-studio/build/bin/data/
*.exe
*.exe~

# Go
*.test
*.out
.gocache/
.gomodcache/
.gopath/

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

